###  https://michaeldebellis.com/people/has_component_transitive
:has_component_transitive rdf:type owl:ObjectProperty ,
                                   owl:TransitiveProperty ;
                          rdfs:label "has component transitive" .


###  https://michaeldebellis.com/people/has_daughter
:has_daughter rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf :has_child ;
              rdf:type owl:IrreflexiveProperty ;
              rdfs:range [ rdf:type owl:Class ;
                           owl:unionOf ( :Girl
                                         :Woman
                                       )
                         ] ;
              rdfs:label "has daughter" .


###  https://michaeldebellis.com/people/has_employer
:has_employer rdf:type owl:ObjectProperty ;
              owl:inverseOf :is_employer_of ;
