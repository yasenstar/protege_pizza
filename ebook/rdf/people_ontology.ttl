@prefix : <https://michaeldebellis.com/people/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix swrl: <http://www.w3.org/2003/11/swrl#> .
@prefix swrla: <http://swrl.stanford.edu/ontologies/3.3/swrla.owl#> .
@prefix swrlb: <http://www.w3.org/2003/11/swrlb#> .
@base <https://michaeldebellis.com/people/> .

<https://michaeldebellis.com/people> rdf:type owl:Ontology ;
                                      dct:creator """Michael DeBellis
Orcid ID: 0000-0002-8824-9577""" ;
                                      dct:license <https://creativecommons.org/licenses/by/4.0/legalcode> ;
                                      skos:definition "A simple example ontology of People, Organizations, Places, and Animals to illustrate basic Semantic Web concepts from RDF, RDFS, OWL, SPARQL and SHACL" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/abstract
dct:abstract rdf:type owl:AnnotationProperty ;
             rdfs:label "abstract" ;
             skos:definition "A summary of the resource." .


###  http://purl.org/dc/terms/contributor
dct:contributor rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/created
dct:created rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
dct:creator rdf:type owl:AnnotationProperty ;
            rdfs:comment "Recommended practice is to identify the creator with a URI. If this is not possible or feasible, a literal value that identifies the creator may be provided." ;
            rdfs:label "creator" ;
            skos:definition "An entity responsible for making the resource." .


###  http://purl.org/dc/terms/license
dct:license rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/subject
dct:subject rdf:type owl:AnnotationProperty ;
            rdfs:comment "Recommended practice is to refer to the subject with a URI. If this is not possible or feasible, a literal value that identifies the subject may be provided. Both should preferably refer to a subject in a controlled vocabulary." ;
            rdfs:label "subject" ;
            skos:definition "A topic of the resource." .


###  http://purl.org/dc/terms/title
dct:title rdf:type owl:AnnotationProperty ;
          rdfs:label "title" ;
          skos:definition "A name given to the resource." .


###  http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled
swrla:isRuleEnabled rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#altLabel
skos:altLabel rdf:type owl:AnnotationProperty ;
              rdfs:isDefinedBy <https://www.w3.org/2012/09/odrl/semantic/draft/doco/http___www.w3.org_2004_02_skos_core.html> ;
              rdfs:label "alternative label"@en ;
              skos:definition "An alternative lexical label for a resource." ;
              skos:example "Acronyms, abbreviations, spelling variants, and irregular plural/singular forms may be included among the alternative labels for a concept. Mis-spelled terms are normally included as hidden labels (see skos:hiddenLabel)." ;
              rdfs:subPropertyOf rdfs:label .


###  http://www.w3.org/2004/02/skos/core#changeNote
skos:changeNote rdf:type owl:AnnotationProperty ;
                rdfs:label "change note"@en ;
                skos:definition "A note about a modification to a concept." ;
                rdfs:subPropertyOf skos:note .


###  http://www.w3.org/2004/02/skos/core#definition
skos:definition rdf:type owl:AnnotationProperty ;
                rdfs:label "definition"@en ;
                skos:definition "A statement or formal explanation of the meaning of a concept." ;
                rdfs:subPropertyOf skos:note .


###  http://www.w3.org/2004/02/skos/core#example
skos:example rdf:type owl:AnnotationProperty ;
             rdfs:label "example"@en ;
             skos:definition "An example of the use of a concept." ;
             rdfs:subPropertyOf skos:note .


###  http://www.w3.org/2004/02/skos/core#note
skos:note rdf:type owl:AnnotationProperty ;
          rdfs:isDefinedBy <https://www.w3.org/2012/09/odrl/semantic/draft/doco/http___www.w3.org_2004_02_skos_core.html> ;
          rdfs:label "note"@en ;
          skos:definition "A general note, for any purpose."@en .


###  http://www.w3.org/2004/02/skos/core#prefLabel
skos:prefLabel rdf:type owl:AnnotationProperty ;
               rdfs:comment "skos:prefLabel, skos:altLabel and skos:hiddenLabel are pairwise disjoint properties.	The range of skos:prefLabel is the class of RDF plain literals. A resource has no more than one value of skos:prefLabel per language tag." ;
               rdfs:isDefinedBy <https://www.w3.org/2012/09/odrl/semantic/draft/doco/http___www.w3.org_2004_02_skos_core.html> ;
               rdfs:label "preferred label"@en ;
               skos:definition "The preferred lexical label for a resource, in a given language." ;
               rdfs:subPropertyOf rdfs:label .


###  https://michaeldebellis.com/people/canonical_unit
:canonical_unit rdf:type owl:AnnotationProperty ;
                dct:contributor "Michael DeBellis" ;
                dct:created "2025-10-13T20:18:59Z"^^xsd:dateTime ;
                rdfs:label "canonical unit"@en ;
                rdfs:range :Unit .


###  https://michaeldebellis.com/people/wikidata
:wikidata rdf:type owl:AnnotationProperty ;
          rdfs:label "wikidata"@en ;
          rdfs:range xsd:anyURI .


#################################################################
#    Object Properties
#################################################################

###  https://michaeldebellis.com/people/born_in
:born_in rdf:type owl:ObjectProperty ;
         rdfs:domain :Person ;
         rdfs:range :Place ;
         dct:contributor "Michael DeBellis" ;
         dct:created "2026-02-06T22:14:21Z"^^xsd:dateTime ;
         rdfs:label "born in"@en .


###  https://michaeldebellis.com/people/contains
:contains rdf:type owl:ObjectProperty ;
          owl:inverseOf :is_contained_in ;
          rdf:type owl:TransitiveProperty ;
          rdfs:label "contains" .


###  https://michaeldebellis.com/people/eats
:eats rdf:type owl:ObjectProperty ;
      rdfs:domain :Animal ;
      rdfs:range :Living_Thing ;
      rdfs:label "eats" .


###  https://michaeldebellis.com/people/equal_to
:equal_to rdf:type owl:ObjectProperty ;
          rdfs:domain :Measurement ;
          rdfs:range :Measurement ;
          dct:contributor "Michael DeBellis" ;
          dct:created "2025-10-03T04:58:19Z"^^xsd:dateTime ;
          rdfs:label "equal to" .


###  https://michaeldebellis.com/people/greater_than
:greater_than rdf:type owl:ObjectProperty ;
              owl:inverseOf :less_than ;
              rdf:type owl:TransitiveProperty ;
              rdfs:domain :Measurement ;
              rdfs:range :Measurement ;
              dct:contributor "Michael DeBellis" ;
              dct:created "2025-10-03T04:58:19Z"^^xsd:dateTime ;
              rdfs:label "greater than" .


###  https://michaeldebellis.com/people/has_address
:has_address rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :has_location ;
             owl:inverseOf :is_address_for ;
             rdfs:domain :Agent ;
             rdfs:range :Address ;
             rdfs:label "has address" .


###  https://michaeldebellis.com/people/has_aunt
:has_aunt rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :has_family_relationship ;
          owl:inverseOf :is_aunt_of ;
          rdf:type owl:IrreflexiveProperty ;
          rdfs:label "has aunt" .


###  https://michaeldebellis.com/people/has_brother
:has_brother rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :has_sibling ;
             rdf:type owl:IrreflexiveProperty ;
             rdfs:range [ rdf:type owl:Class ;
                          owl:unionOf ( :Boy
                                        :Man
                                      )
                        ] ;
             rdfs:label "has brother" .


###  https://michaeldebellis.com/people/has_child
:has_child rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf :has_family_relationship ;
           owl:inverseOf :has_parent ;
           rdf:type owl:IrreflexiveProperty ;
           rdfs:label "has child" .


###  https://michaeldebellis.com/people/has_city
:has_city rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :has_location ;
          rdfs:domain :Address ;
          rdfs:range :City ;
          rdfs:label "has city" .


###  https://michaeldebellis.com/people/has_colleague
:has_colleague rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf :has_social_relationship ;
               rdf:type owl:SymmetricProperty ,
                        owl:IrreflexiveProperty ;
               rdfs:label "has colleague" .


###  https://michaeldebellis.com/people/has_component
:has_component rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf :has_component_transitive ;
